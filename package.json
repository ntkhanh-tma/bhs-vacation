{
  "name": "vacation-planner",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/setup-env.js",
    "start": "ng serve",
    "prebuild": "node scripts/setup-env.js",
    "build": "ng build",
    "build:prod": "node scripts/setup-env.js && ng build --configuration=production",
    "watch": "ng build --watch --configuration development",
    "setup-env": "node scripts/setup-env.js"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.0",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.25",
    "@angular/cli": "^20.3.25",
    "@angular/compiler-cli": "^20.3.0",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2"
  }
}
